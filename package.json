{
  "name": "maixcode",
  "displayName": "MaixCode",
  "description": "MaixVision on VSCode",
  "version": "0.0.1",
  "publisher": "Cranyozen",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./dist/extension.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MaixCode/MaixCode.git"
  },
  "homepage": "https://github.com/MaixCode/MaixCode",
  "bugs": {
    "url": "https://github.com/MaixCode/MaixCode/issues"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "maixcode-mainview",
          "title": "MaixCode",
          "icon": "$(circuit-board)"
        },
        {
          "id": "maixcode-toolview",
          "title": "MaixTool",
          "icon": "$(tools)"
        }
      ]
    },
    "views": {
      "maixcode-mainview": [
        {
          "id": "maixcode-devices",
          "name": "Device",
          "icon": "$(vm-outline)"
        },
        {
          "id": "maixcode-example",
          "name": "Example",
          "icon": "$(folder-library)"
        }
      ]
    },
    "commands": [
      {
        "command": "maixcode.connectDevice",
        "title": "Connect Device",
        "icon": "$(vm-connect)",
        "category": "MaixCode"
      },
      {
        "command": "maixcode.disconnectDevice",
        "title": "Disconnect Device",
        "icon": "$(debug-disconnect)",
        "category": "MaixCode"
      },
      {
        "command": "maixcode.openDeviceTerminal",
        "title": "Open SSH Terminal",
        "icon": "$(terminal)",
        "category": "MaixCode"
      },
      {
        "command": "maixcode.openDeviceSftp",
        "title": "Open Device Files (SFTP)",
        "icon": "$(folder-opened)",
        "category": "MaixCode"
      },
      {
        "command": "maixcode.discoverDevice",
        "title": "Discover Devices",
        "category": "MaixCode"
      },
      {
        "command": "maixcode.refreshDeviceData",
        "title": "Refresh Devices",
        "icon": "$(refresh)",
        "category": "MaixCode"
      },
      {
        "command": "maixcode.refreshExample",
        "title": "Refresh Examples",
        "icon": "$(refresh)",
        "category": "MaixCode"
      },
      {
        "command": "maixcode.refreshExampleSource",
        "title": "Refresh Example Source",
        "icon": "$(refresh)",
        "category": "MaixCode"
      },
      {
        "command": "maixcode.openExample",
        "title": "Open Example",
        "category": "MaixCode"
      },
      {
        "command": "maixcode.openExampleSource",
        "title": "Open Source File (may be overwritten)",
        "category": "MaixCode"
      },
      {
        "command": "maixcode.openImageViewer",
        "title": "Open Image Viewer",
        "category": "MaixCode"
      },
      {
        "command": "maixcode.runOnDevice",
        "title": "Run Current File on Device",
        "icon": "$(play)",
        "category": "MaixCode"
      },
      {
        "command": "maixcode.sftpFilterPath",
        "title": "Filter (Hide in SFTP)",
        "category": "MaixCode",
        "icon": "$(filter)"
      },
      {
        "command": "maixcode.sftpUnfilterPath",
        "title": "Unfilter (Show in SFTP)",
        "category": "MaixCode",
        "icon": "$(filter-filled)"
      },
      {
        "command": "maixcode.sftpToggleShowFiltered",
        "title": "Toggle Show Filtered SFTP Items",
        "category": "MaixCode"
      },
      {
        "command": "maixcode.sftpEditFilterPatterns",
        "title": "Edit SFTP Filter Patterns",
        "category": "MaixCode"
      },
      {
        "command": "maixcode.sftpRefresh",
        "title": "Refresh SFTP",
        "icon": "$(refresh)",
        "category": "MaixCode"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "maixcode.refreshDeviceData",
          "when": "view == maixcode-devices",
          "group": "navigation"
        },
        {
          "command": "maixcode.refreshExample",
          "when": "view == maixcode-example",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "maixcode.connectDevice",
          "when": "viewItem == maixcode-deviceIp",
          "group": "inline"
        },
        {
          "command": "maixcode.openDeviceTerminal",
          "when": "viewItem == maixcode-deviceIp",
          "group": "inline@2"
        },
        {
          "command": "maixcode.openDeviceSftp",
          "when": "viewItem == maixcode-deviceIp",
          "group": "inline@3"
        },
        {
          "command": "maixcode.refreshExampleSource",
          "when": "view == maixcode-example && viewItem == exampleSource",
          "group": "inline"
        },
        {
          "command": "maixcode.openExampleSource",
          "when": "view == maixcode-example && viewItem == file",
          "group": "1_open@1"
        }
      ],
      "editor/title": [
        {
          "command": "maixcode.runOnDevice",
          "when": "resourceLangId == python",
          "group": "navigation"
        },
        {
          "command": "maixcode.sftpRefresh",
          "when": "resourceScheme == maixsftp",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "maixcode.runOnDevice",
          "when": "resourceLangId == python",
          "group": "navigation@1"
        }
      ],
      "explorer/context": [
        {
          "command": "maixcode.sftpRefresh",
          "when": "resourceScheme == maixsftp",
          "group": "navigation@1"
        },
        {
          "command": "maixcode.sftpFilterPath",
          "when": "resourceScheme == maixsftp",
          "group": "maixcode@1"
        },
        {
          "command": "maixcode.sftpUnfilterPath",
          "when": "resourceScheme == maixsftp",
          "group": "maixcode@2"
        },
        {
          "command": "maixcode.sftpToggleShowFiltered",
          "when": "resourceScheme == maixsftp",
          "group": "maixcode@3"
        },
        {
          "command": "maixcode.sftpEditFilterPatterns",
          "when": "resourceScheme == maixsftp",
          "group": "maixcode@4"
        }
      ]
    },
    "debuggers": [
      {
        "type": "maixpy",
        "label": "MaixPy Debug",
        "languages": [
          "python"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Absolute path to the MaixPy/Python file to run on the device",
                "default": "${file}"
              },
              "noDebug": {
                "type": "boolean",
                "description": "Run without debug UI extras",
                "default": true
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "maixpy",
            "request": "launch",
            "name": "MaixPy: Run Current File on Device",
            "program": "${file}"
          }
        ],
        "configurationSnippets": [
          {
            "label": "MaixPy: Run Current File on Device",
            "description": "Send the current Python file to a connected MaixCAM",
            "body": {
              "type": "maixpy",
              "request": "launch",
              "name": "MaixPy: Run Current File on Device",
              "program": "${file}"
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "MaixCode",
      "properties": {
        "maixcode.enableDeviceDiscovery": {
          "type": "boolean",
          "default": true,
          "description": "Enable device discovery"
        },
        "maixcode.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically connect when a MaixCAM is discovered and no device is connected"
        },
        "maixcode.autoConnectTarget": {
          "type": "string",
          "default": "",
          "description": "Preferred device for auto-connect: device hostname (e.g. maixcam-xxxx.local) or IP. Empty = last connected device, then first discovered."
        },
        "maixcode.imageServicePort": {
          "type": "number",
          "default": 9090,
          "minimum": 0,
          "maximum": 65535,
          "description": "Local image service port (HTTP / WebSocket / MJPEG). 0 = ephemeral. If bind fails, falls back to ephemeral."
        },
        "maixcode.imageViewerDefaultMode": {
          "type": "string",
          "default": "websocket",
          "enum": [
            "http",
            "websocket",
            "mjpeg"
          ],
          "enumDescriptions": [
            "Poll GET /image/:key",
            "WebSocket subscribe push",
            "MJPEG multipart stream"
          ],
          "description": "Default transport in the Image Preview panel"
        },
        "maixcode.imageHttpIntervalMs": {
          "type": "number",
          "default": 33,
          "minimum": 16,
          "maximum": 2000,
          "description": "Default HTTP poll interval (ms) in Image Preview (~30fps at 33)"
        },
        "maixcode.imageViewerAutoStart": {
          "type": "boolean",
          "default": true,
          "description": "Auto-start stream when Image Preview opens with a connected device"
        },
        "maixcode.exampleSources": {
          "type": "array",
          "default": [
            {
              "id": "sipeed",
              "type": "sipeed",
              "label": "Official"
            }
          ],
          "description": "Example sources as first-level folders. Types: sipeed | local_folder | github_repo.",
          "items": {
            "type": "object",
            "required": [
              "id",
              "type"
            ],
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique id; used as cache folder name under sources/<id>/"
              },
              "type": {
                "type": "string",
                "enum": [
                  "sipeed",
                  "local_folder",
                  "github_repo"
                ]
              },
              "label": {
                "type": "string",
                "description": "Display name in the Example tree"
              },
              "baseUrl": {
                "type": "string",
                "description": "sipeed CDN base URL"
              },
              "path": {
                "type": "string",
                "description": "local_folder: absolute path, ~/..., or ${workspaceFolder}/..."
              },
              "owner": {
                "type": "string",
                "description": "github_repo: owner"
              },
              "repo": {
                "type": "string",
                "description": "github_repo: repository name"
              },
              "ref": {
                "type": "string",
                "description": "github_repo: branch, tag, or commit (default main)"
              },
              "subdir": {
                "type": "string",
                "description": "github_repo: optional subdirectory inside the repo"
              },
              "token": {
                "type": "string",
                "description": "github_repo: optional token (prefer maixcode.githubToken)"
              }
            }
          }
        },
        "maixcode.githubToken": {
          "type": "string",
          "default": "",
          "description": "Optional GitHub token for private example repos (maixcode.exampleSources type github_repo)."
        },
        "maixcode.sshPort": {
          "type": "number",
          "default": 22,
          "description": "Default SSH port for device terminals"
        },
        "maixcode.sshConnectTimeoutMs": {
          "type": "number",
          "default": 10000,
          "description": "SSH connect timeout (ms) per credential attempt"
        },
        "maixcode.sshCredentials": {
          "type": "array",
          "default": [
            {
              "username": "root",
              "password": "root"
            }
          ],
          "description": "SSH credentials tried in order until one succeeds (username/password). Passwords are stored in settings in plain text.",
          "items": {
            "type": "object",
            "required": [
              "username"
            ],
            "properties": {
              "username": {
                "type": "string",
                "description": "SSH username"
              },
              "password": {
                "type": "string",
                "default": "",
                "description": "SSH password"
              },
              "label": {
                "type": "string",
                "description": "Optional label for logs only"
              }
            }
          }
        },
        "maixcode.sftpRoot": {
          "type": "string",
          "default": "/",
          "description": "Remote directory mounted when opening device SFTP (POSIX path)."
        },
        "maixcode.sftpReadOnly": {
          "type": "boolean",
          "default": false,
          "description": "When true, SFTP virtual filesystem is read-only."
        },
        "maixcode.sftpHidePatterns": {
          "type": "array",
          "default": [
            ".*",
            "proc",
            "sys",
            "dev",
            "run",
            "tmp",
            "*.ko",
            "/lib/**",
            "/usr/lib/**",
            "/var/log/**",
            "/^core\\.\\d+$/"
          ],
          "description": "Hide matching names/paths from SFTP Explorer. Glob (* ? **) or /regex/flags. Right-click a folder/file → Filter (Hide in SFTP) adds its full path. Use Toggle Show Filtered SFTP Items to reveal badges on filtered entries.",
          "items": {
            "type": "string"
          }
        },
        "maixcode.sftpShowFiltered": {
          "type": "boolean",
          "default": false,
          "description": "When true, SFTP entries matching hide patterns still appear in Explorer with an \"H\" badge and tooltip (so you can Unfilter). When false, they are fully hidden."
        },
        "maixcode.autoOpenSftp": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open device SFTP (maixsftp workspace folder) when a device connects. Uses maixcode.sshCredentials and maixcode.sftpRoot. Quiet mode (no toast / no Explorer focus)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test",
    "package:vsix": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/mocha": "^10.0.7",
    "@types/multicast-dns": "^7.2.4",
    "@types/node": "20.x",
    "@types/ssh2": "^1.15.5",
    "@types/vscode": "^1.92.0",
    "@types/ws": "^8.5.12",
    "@types/yamljs": "^0.2.34",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.11.0",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.6.0",
    "eslint": "^8.57.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.5",
    "webpack": "^5.92.1",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.1",
    "@vscode/debugadapter": "^1.66.0",
    "@vscode/debugprotocol": "^1.68.0",
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "axios": "^1.7.7",
    "dayjs": "^1.11.12",
    "express": "^4.21.2",
    "fabric": "^6.5.3",
    "jszip": "^3.10.1",
    "multicast-dns": "^7.2.5",
    "sharp": "^0.33.5",
    "ssh2": "^1.17.0",
    "ws": "^8.18.0",
    "yamljs": "^0.3.0"
  }
}
