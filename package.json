{
  "name": "maixcode",
  "displayName": "MaixCode",
  "description": "MaixVision on VSCode",
  "version": "0.0.1",
  "publisher": "Cranyozen",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "maixcode-mainview",
          "title": "MaixCode",
          "icon": "$(circuit-board)"
        },
        {
          "id": "maixcode-toolview",
          "title": "MaixTool",
          "icon": "$(tools)"
        }
      ]
    },
    "views": {
      "maixcode-mainview": [
        {
          "id": "maixcode-devices",
          "name": "Device",
          "icon": "$(vm-outline)"
        },
        {
          "id": "maixcode-example",
          "name": "Example",
          "icon": "$(folder-library)"
        }
      ]
    },
    "commands": [
      {
        "command": "maixcode.connectDevice",
        "title": "Connect Device",
        "icon": "$(vm-connect)",
        "category": "MaixCode"
      },
      {
        "command": "maixcode.disconnectDevice",
        "title": "Disconnect Device",
        "icon": "$(debug-disconnect)",
        "category": "MaixCode"
      },
      {
        "command": "maixcode.discoverDevice",
        "title": "Discover Devices",
        "category": "MaixCode"
      },
      {
        "command": "maixcode.refreshDeviceData",
        "title": "Refresh Devices",
        "icon": "$(refresh)",
        "category": "MaixCode"
      },
      {
        "command": "maixcode.refreshExample",
        "title": "Refresh Examples",
        "icon": "$(refresh)",
        "category": "MaixCode"
      },
      {
        "command": "maixcode.refreshExampleSource",
        "title": "Refresh Example Source",
        "icon": "$(refresh)",
        "category": "MaixCode"
      },
      {
        "command": "maixcode.openExample",
        "title": "Open Example",
        "category": "MaixCode"
      },
      {
        "command": "maixcode.openImageViewer",
        "title": "Open Image Viewer",
        "category": "MaixCode"
      },
      {
        "command": "maixcode.runOnDevice",
        "title": "Run Current File on Device",
        "icon": "$(play)",
        "category": "MaixCode"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "maixcode.refreshDeviceData",
          "when": "view == maixcode-devices",
          "group": "navigation"
        },
        {
          "command": "maixcode.refreshExample",
          "when": "view == maixcode-example",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "maixcode.connectDevice",
          "when": "viewItem == maixcode-deviceIp",
          "group": "inline"
        },
        {
          "command": "maixcode.refreshExampleSource",
          "when": "view == maixcode-example && viewItem == exampleSource",
          "group": "inline"
        }
      ],
      "editor/title": [
        {
          "command": "maixcode.runOnDevice",
          "when": "resourceLangId == python",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "maixcode.runOnDevice",
          "when": "resourceLangId == python",
          "group": "navigation@1"
        }
      ]
    },
    "debuggers": [
      {
        "type": "maixpy",
        "label": "MaixPy Debug",
        "languages": [
          "python"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Absolute path to the MaixPy/Python file to run on the device",
                "default": "${file}"
              },
              "noDebug": {
                "type": "boolean",
                "description": "Run without debug UI extras",
                "default": true
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "maixpy",
            "request": "launch",
            "name": "MaixPy: Run Current File on Device",
            "program": "${file}"
          }
        ],
        "configurationSnippets": [
          {
            "label": "MaixPy: Run Current File on Device",
            "description": "Send the current Python file to a connected MaixCAM",
            "body": {
              "type": "maixpy",
              "request": "launch",
              "name": "MaixPy: Run Current File on Device",
              "program": "${file}"
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "MaixCode",
      "properties": {
        "maixcode.enableDeviceDiscovery": {
          "type": "boolean",
          "default": true,
          "description": "Enable device discovery"
        },
        "maixcode.exampleSources": {
          "type": "array",
          "default": [
            {
              "id": "sipeed",
              "type": "sipeed",
              "label": "Official"
            }
          ],
          "description": "Example sources as first-level folders. Types: sipeed | local_folder | github_repo.",
          "items": {
            "type": "object",
            "required": [
              "id",
              "type"
            ],
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique id; used as cache folder name under sources/<id>/"
              },
              "type": {
                "type": "string",
                "enum": [
                  "sipeed",
                  "local_folder",
                  "github_repo"
                ]
              },
              "label": {
                "type": "string",
                "description": "Display name in the Example tree"
              },
              "baseUrl": {
                "type": "string",
                "description": "sipeed CDN base URL"
              },
              "path": {
                "type": "string",
                "description": "local_folder: absolute path or ${workspaceFolder}/..."
              },
              "owner": {
                "type": "string",
                "description": "github_repo: owner"
              },
              "repo": {
                "type": "string",
                "description": "github_repo: repository name"
              },
              "ref": {
                "type": "string",
                "description": "github_repo: branch, tag, or commit (default main)"
              },
              "subdir": {
                "type": "string",
                "description": "github_repo: optional subdirectory inside the repo"
              },
              "token": {
                "type": "string",
                "description": "github_repo: optional token (prefer maixcode.githubToken)"
              }
            }
          }
        },
        "maixcode.githubToken": {
          "type": "string",
          "default": "",
          "description": "Optional GitHub token for private example repos (maixcode.exampleSources type github_repo)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "yarn run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "yarn run compile-tests && yarn run compile && yarn run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/mocha": "^10.0.7",
    "@types/multicast-dns": "^7.2.4",
    "@types/node": "20.x",
    "@types/vscode": "^1.92.0",
    "@types/ws": "^8.5.12",
    "@types/yamljs": "^0.2.34",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.11.0",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.4.0",
    "eslint": "^8.57.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.5",
    "webpack": "^5.92.1",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.1",
    "@vscode/debugadapter": "^1.66.0",
    "@vscode/debugprotocol": "^1.68.0",
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "axios": "^1.7.7",
    "dayjs": "^1.11.12",
    "express": "^4.21.2",
    "fabric": "^6.5.3",
    "jszip": "^3.10.1",
    "multicast-dns": "^7.2.5",
    "sharp": "^0.33.5",
    "ws": "^8.18.0",
    "yamljs": "^0.3.0"
  }
}
