NOTICE

# vsce uses --packagedDependencies ssh2: only the native SSH stack is
# collected from node_modules. Pure JS deps are webpack-bundled.
# Drop compile/test/docs junk and native build-only packages (nan/buildcheck).
node_modules/**
# !node_modules/ssh2/**